# Copy this file to .env and fill in real values. .env is gitignored.
#
# Anthropic API key for LLM calls.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith API key for tracing.
# Get one at: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_pt_...

# LangSmith project name (auto-created on first trace).
LANGSMITH_PROJECT=filings-watcher

# Enable tracing. Set to "false" to disable LangSmith export entirely.
LANGSMITH_TRACING=true
