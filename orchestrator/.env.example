# Copy this file to .env and fill in real values. .env is gitignored.
# Values are split between credentials (treat as sensitive) and required
# configuration (mandatory for the app to run, but not a credential).

# --- Credentials ---

# Anthropic API key. Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith API key. Get one at: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_pt_...

# --- Required configuration ---

# LangSmith project name (auto-created on first trace).
LANGSMITH_PROJECT=filings-watcher

# Enable tracing. Set to "false" to disable LangSmith export entirely.
LANGSMITH_TRACING=true

# SEC EDGAR requires a descriptive User-Agent on every request. Without it,
# requests are blocked. Format: "<app name> <contact email>".
# Not a credential — it's identification, and is sent in every request.
# Reference: https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT=filings-watcher you@example.com

# Path to the SQLite filings database. Leave commented to use the default
# ~/.filings-watcher/v0.db. Override for ephemeral dev DBs (e.g., /tmp/dev.db)
# or container deploys (e.g., /data/v0.db).
# FILINGS_DB_PATH=~/.filings-watcher/v0.db
