{{- /* Company view: one company's material classifications, grouped by CIK, paginated. */ -}}
{{define "title"}}{{.Company.CompanyName}}{{if .Company.Ticker}} ({{.Company.Ticker}}){{end}} — filings{{end}}
{{define "content"}}
<nav class="detail-back" aria-label="Breadcrumb">
  <a href="/">&larr; Back to all filings</a>
</nav>

<section class="company-header">
  <h2>
    {{.Company.CompanyName}}
    {{if .Company.Ticker}} <small>({{.Company.Ticker}})</small>{{end}}
  </h2>
  <div class="filing-meta">
    <span>CIK {{.Company.CIK}}</span>
    <span>{{.FilingTotal}} material event{{if ne .FilingTotal 1}}s{{end}}</span>
  </div>
</section>

<section class="insider-activity">
  <h3>Insider activity <small>(SEC Form 4)</small></h3>
  {{if or .Pulse30.HasActivity .Pulse90.HasActivity .InsiderTrades}}
    <p class="reasoning">Open-market buys and sells only &mdash; the deliberate trades. Zero here doesn&rsquo;t mean no filings: grants, option exercises and tax withholding (below) are compensation, not market trades.</p>
    <div class="filing-meta">
      <span><strong>Open-market &middot; last 30 days:</strong></span>
      <span class="badge">{{.Pulse30.Buyers}} buyer{{if ne .Pulse30.Buyers 1}}s{{end}} bought {{usd .Pulse30.BuyValue}}</span>
      <span class="badge">{{.Pulse30.Sellers}} seller{{if ne .Pulse30.Sellers 1}}s{{end}} sold {{usd .Pulse30.SellValue}}</span>
    </div>
    <div class="filing-meta">
      <span><strong>Open-market &middot; last 90 days:</strong></span>
      <span>{{.Pulse90.Buyers}} buyer{{if ne .Pulse90.Buyers 1}}s{{end}} bought {{usd .Pulse90.BuyValue}}</span>
      <span>{{.Pulse90.Sellers}} seller{{if ne .Pulse90.Sellers 1}}s{{end}} sold {{usd .Pulse90.SellValue}}</span>
    </div>
    {{if .InsiderTrades}}
      <table class="insider-trades">
        <thead><tr><th>Insider</th><th>Role</th><th>Date</th><th>Transaction</th><th>Shares</th><th>Value</th></tr></thead>
        <tbody>
          {{range .InsiderTrades}}
            <tr>
              <td>{{.OwnerName}}</td>
              <td>{{.Role}}</td>
              <td>{{.TransactionDate}}</td>
              <td>{{txnLabel .Code}}{{if .Is10b51}} <span class="badge">10b5-1</span>{{end}}</td>
              <td>{{printf "%.0f" .Shares}}</td>
              <td>{{usdp .Value}}</td>
            </tr>
          {{end}}
        </tbody>
      </table>
      <small>Most recent {{len .InsiderTrades}} reported transactions. Open-market buys (P) and sells (S) are the deliberate ones; grants and option exercises are compensation. Not investment advice.</small>
    {{end}}
  {{else}}
    <p>No insider (Form&nbsp;4) transactions on record for this company yet.</p>
  {{end}}
</section>

{{if .Events}}
  <section>
    {{range .Events}}
      <article class="filing-card">
        <h3><a href="/filings/{{.AccessionNumber}}">{{eventLabel .EventType}}</a></h3>
        <div class="filing-meta">
          {{if .Form}}<span class="badge form">{{.Form}}</span>{{end}}
          <span>filed {{.FilingDate}}</span>
          <span>confidence {{printf "%.0f" (mul .Confidence 100.0)}}%</span>
          {{if .AnchorItemNumber}}<span>{{ anchorLabel .AnchorItemNumber }}</span>{{end}}
        </div>
        <p class="reasoning">{{.Summary}}</p>
        <small><a href="{{edgarURL .AccessionNumber}}" rel="noopener" target="_blank">View raw filing on EDGAR &rarr;</a></small>
      </article>
    {{end}}
  </section>

  {{if or .PrevURL .NextURL}}
    <nav class="pagination" aria-label="Pagination">
      {{if .PrevURL}}
        <a href="{{.PrevURL}}">&larr; Newer</a>
      {{else}}
        <span class="disabled">&larr; Newer</span>
      {{end}}
      <span>{{.RangeStart}}-{{.RangeEnd}} of {{.FilingTotal}}</span>
      {{if .NextURL}}
        <a href="{{.NextURL}}">Older &rarr;</a>
      {{else}}
        <span class="disabled">Older &rarr;</span>
      {{end}}
    </nav>
  {{end}}
{{else}}
  <p>We track this company, but none of its filings have been classified as material yet. New filings land after EDGAR&rsquo;s nightly publish (~10 PM ET).</p>
{{end}}
{{end}}
