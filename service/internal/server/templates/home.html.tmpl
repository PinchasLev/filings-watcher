{{- /* Home page: latest material classifications, filterable by event_type, paginated. */ -}}
{{define "title"}}Filings Radar — recent material 8-K events{{end}}
{{define "content"}}
{{if .TickerNotFound}}
<p class="notice">
  No company found for ticker &ldquo;{{.SearchedTicker}}&rdquo;. It may not be an active SEC ticker, or we haven&rsquo;t ingested it yet. Showing the latest filings below.
</p>
{{end}}
<nav class="filter-nav" aria-label="Filter by event type">
  <a href="/" {{if eq .ActiveEventType ""}}class="active"{{end}}>
    All material <span class="count">{{.TotalMaterial}}</span>
  </a>
  {{range .EventTypeCounts}}
    <a href="/?event={{.EventType}}" {{if eq $.ActiveEventType .EventType}}class="active"{{end}}>
      {{eventLabel .EventType}} <span class="count">{{.Count}}</span>
    </a>
  {{end}}
</nav>

<p class="intro">
  Showing material events only. Routine administrative filings — bylaw amendments, technical fund updates, procedural FD disclosures — are filtered out so the front page stays signal-dense.
</p>

{{if .Filings}}
  <section>
    {{range .Filings}}
      <article class="filing-card">
        <h3>
          <a href="/filings/{{.AccessionNumber}}">{{.CompanyName}}</a>
          {{if .Ticker}} <small>({{ derefStr .Ticker }})</small>{{end}}
        </h3>
        <div class="filing-meta">
          <span class="badge">{{eventLabel .EventType}}</span>
          <span>confidence {{printf "%.0f" (mul .Confidence 100.0)}}%</span>
          <span>filed {{.FilingDate}}</span>
          {{if .ItemNumber}}<span>Item {{ derefStr .ItemNumber }}</span>{{end}}
        </div>
        <p class="reasoning">{{.Reasoning}}</p>
        <small><a href="{{edgarURL .AccessionNumber}}" rel="noopener" target="_blank">View raw filing on EDGAR &rarr;</a></small>
      </article>
    {{end}}
  </section>

  {{if or .PrevURL .NextURL}}
    <nav class="pagination" aria-label="Pagination">
      {{if .PrevURL}}
        <a href="{{.PrevURL}}">&larr; Newer</a>
      {{else}}
        <span class="disabled">&larr; Newer</span>
      {{end}}
      <span>{{.RangeStart}}-{{.RangeEnd}} of {{.FilteredTotal}}</span>
      {{if .NextURL}}
        <a href="{{.NextURL}}">Older &rarr;</a>
      {{else}}
        <span class="disabled">Older &rarr;</span>
      {{end}}
    </nav>
  {{end}}
{{else}}
  <p>No classifications match the current filter. The orchestrator runs every 15 minutes; new filings land after EDGAR's nightly publish around 10 PM ET.</p>
{{end}}
{{end}}
