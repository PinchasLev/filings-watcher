{{- /* Base layout used by every server-rendered page. */ -}}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{block "title" .}}Filings Radar{{end}}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
<style>
  :root { --pico-typography-spacing-vertical: 1rem; }
  .filter-nav { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1.5rem 0; }
  .filter-nav a {
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.9rem;
    background: var(--pico-card-background-color);
    border: 1px solid var(--pico-muted-border-color);
    color: var(--pico-color);
  }
  .filter-nav a.active {
    background: var(--pico-primary);
    color: var(--pico-primary-inverse);
    border-color: var(--pico-primary);
  }
  .filter-nav a .count { opacity: 0.7; margin-left: 0.25rem; }
  .intro {
    font-size: 0.95rem;
    color: var(--pico-muted-color);
    margin-bottom: 1.5rem;
  }
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--pico-muted-border-color);
    font-size: 0.9rem;
  }
  .pagination a { text-decoration: none; }
  .pagination .disabled { color: var(--pico-muted-color); pointer-events: none; }
  .filing-card {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--pico-muted-border-color);
  }
  .filing-card:last-child { border-bottom: none; }
  .filing-card h3 { margin-bottom: 0.25rem; }
  .filing-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--pico-muted-color);
    margin-bottom: 0.75rem;
  }
  .badge {
    padding: 0.15rem 0.55rem;
    border-radius: 0.3rem;
    background: var(--pico-secondary-background);
    color: var(--pico-secondary);
    font-size: 0.75rem;
    text-transform: lowercase;
    font-weight: 600;
  }
  .badge.material {
    background: var(--pico-color-amber-100);
    color: var(--pico-color-amber-800);
  }
  .reasoning { font-size: 0.95rem; line-height: 1.5; }
  /* Detail-page-specific elements. */
  .detail-back { margin-bottom: 1rem; font-size: 0.9rem; }
  .filing-detail { margin-bottom: 2rem; }
  .filing-detail h2 { margin-bottom: 0.5rem; }
  .classifications h3 { margin-top: 2rem; }
  .version-info { color: var(--pico-muted-color); font-size: 0.8rem; }
  .filing-card h4 { margin-bottom: 0.4rem; font-size: 1rem; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--pico-muted-border-color); font-size: 0.85rem; color: var(--pico-muted-color); }
</style>
</head>
<body>
<main class="container">
  <header>
    <hgroup>
      <h1>Filings Radar</h1>
      <p>SEC 8-K filings, classified by Claude with reasoning. Updated nightly from EDGAR's daily index (~10 PM ET).</p>
    </hgroup>
  </header>
  {{block "content" .}}{{end}}
  <footer>
    Open source on GitHub: <a href="https://github.com/PinchasLev/filings-watcher">github.com/PinchasLev/filings-watcher</a>
  </footer>
</main>
</body>
</html>
