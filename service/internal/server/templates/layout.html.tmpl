{{- /* Base layout used by every server-rendered page. */ -}}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{block "title" .}}Filings Radar{{end}}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
<style>
  :root { --pico-typography-spacing-vertical: 1rem; }
  .filter-nav { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1.5rem 0; }
  .filter-nav a {
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.9rem;
    background: var(--pico-card-background-color);
    border: 1px solid var(--pico-muted-border-color);
    color: var(--pico-color);
  }
  .filter-nav a.active {
    background: var(--pico-primary);
    color: var(--pico-primary-inverse);
    border-color: var(--pico-primary);
  }
  .filter-nav a .count { opacity: 0.7; margin-left: 0.25rem; }
  .intro {
    font-size: 0.95rem;
    color: var(--pico-muted-color);
    margin-bottom: 1.5rem;
  }
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--pico-muted-border-color);
    font-size: 0.9rem;
  }
  .pagination a { text-decoration: none; }
  .pagination .disabled { color: var(--pico-muted-color); pointer-events: none; }
  .filing-card {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--pico-muted-border-color);
  }
  .filing-card:last-child { border-bottom: none; }
  .filing-card h3 { margin-bottom: 0.25rem; }
  .filing-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--pico-muted-color);
    margin-bottom: 0.75rem;
  }
  .badge {
    padding: 0.15rem 0.55rem;
    border-radius: 0.3rem;
    background: var(--pico-secondary-background);
    color: var(--pico-secondary);
    font-size: 0.75rem;
    text-transform: lowercase;
    font-weight: 600;
  }
  .badge.material {
    background: var(--pico-color-amber-100);
    color: var(--pico-color-amber-800);
  }
  .reasoning { font-size: 0.95rem; line-height: 1.5; }
  /* Ticker search (in the header, on every page). */
  .search { display: flex; gap: 0.5rem; margin-top: 1rem; max-width: 26rem; }
  .search input { margin-bottom: 0; }
  .search button { width: auto; margin-bottom: 0; white-space: nowrap; }
  .notice {
    padding: 0.75rem 1rem;
    border-radius: 0.4rem;
    background: var(--pico-color-amber-100);
    color: var(--pico-color-amber-800);
    font-size: 0.95rem;
    margin: 1.5rem 0;
  }
  /* Company-view header. */
  .company-header { margin-bottom: 1rem; }
  .company-header h2 { margin-bottom: 0.25rem; }
  /* Detail-page-specific elements. */
  .detail-back { margin-bottom: 1rem; font-size: 0.9rem; }
  .filing-detail { margin-bottom: 2rem; }
  .filing-detail h2 { margin-bottom: 0.5rem; }
  .classifications h3, .events h3 { margin-top: 2rem; }
  .version-info { color: var(--pico-muted-color); font-size: 0.8rem; }
  .filing-card h4 { margin-bottom: 0.4rem; font-size: 1rem; }
  /* Detail-page event drill-down: each event expands to its source Items. */
  .event-items { margin-top: 0.5rem; }
  .event-items summary { cursor: pointer; font-size: 0.85rem; color: var(--pico-muted-color); }
  .item-classification {
    margin-top: 1rem;
    padding-left: 1rem;
    border-left: 2px solid var(--pico-muted-border-color);
  }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--pico-muted-border-color); font-size: 0.85rem; color: var(--pico-muted-color); }
</style>
</head>
<body>
<main class="container">
  <header>
    <hgroup>
      <h1><a href="/" style="text-decoration: none; color: inherit;">Filings Radar</a></h1>
      <p>SEC 8-K filings, classified by Claude with reasoning. Updated nightly from EDGAR's daily index (~10 PM ET).</p>
    </hgroup>
    <form class="search" method="get" action="/" role="search">
      <input type="search" name="ticker" placeholder="Search by ticker — e.g. AAPL"
             aria-label="Search by ticker symbol" autocapitalize="characters" autocomplete="off">
      <button type="submit">Search</button>
    </form>
  </header>
  {{block "content" .}}{{end}}
  <footer>
    Open source on GitHub: <a href="https://github.com/PinchasLev/filings-watcher">github.com/PinchasLev/filings-watcher</a>
  </footer>
</main>
</body>
</html>
