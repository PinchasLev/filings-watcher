{{- /* Live tape: material 8-K events ordered by precise EDGAR submission time.
       New events are prepended into #live-tape by /static/live.js polling
       /api/live-events; the same `filing-card` partial backs both the initial
       server render and the AJAX-injected fragments, so there's one source
       of truth for card markup. */ -}}
{{define "title"}}Filings Radar — live tape{{end}}
{{define "filing-card"}}
<article class="filing-card" data-accession="{{.AccessionNumber}}">
  <h3>
    <a href="/filings/{{.AccessionNumber}}">{{.CompanyName}}</a>
    {{if .Ticker}} <small>({{ derefStr .Ticker }})</small>{{end}}
  </h3>
  <div class="filing-meta">
    <span class="badge">{{eventLabel .EventType}}</span>
    <span>confidence {{printf "%.0f" (mul .Confidence 100.0)}}%</span>
    {{if .SubmittedAt -}}
    <time class="submitted-at" datetime="{{ derefStr .SubmittedAt }}">{{utcDateTime .SubmittedAt}}</time>
    {{- end}}
    {{if .AnchorItemNumber}}<span>{{ anchorLabel .AnchorItemNumber }}</span>{{end}}
  </div>
  <p class="reasoning">{{.Summary}}</p>
  <small><a href="{{edgarURL .AccessionNumber}}" rel="noopener" target="_blank">View raw filing on EDGAR &rarr;</a></small>
</article>
{{end}}
{{define "content"}}
<nav class="filter-nav" aria-label="Window">
  {{$active := .WindowHours}}
  {{range .WindowOptions}}
    <a href="{{liveWindowURL .}}" {{if eq . $active}}class="active"{{end}}>
      Last {{if eq . 1}}hour{{else if eq . 24}}24 hours{{else}}{{.}} hours{{end}}
    </a>
  {{end}}
</nav>

<p class="intro">
  Material 8-K and 6-K events ordered by the time EDGAR accepted them. New filings appear at the top automatically — no refresh needed. Only filings ingested in near-real-time appear here; the daily-index reconciliation backstop fills in the catalog overnight, but those rows don't carry a sub-day timestamp and land on the <a href="/">Latest</a> view instead.
</p>

<section id="live-tape">
  {{range .Events}}
    {{template "filing-card" .}}
  {{end}}
</section>

{{if not .Events}}
  <p id="live-tape-empty">No filings in this window yet. New ones will appear automatically.</p>
{{end}}

{{if or .PrevURL .NextURL}}
  <nav class="pagination" aria-label="Pagination">
    {{if .PrevURL}}
      <a href="{{.PrevURL}}">&larr; Newer</a>
    {{else}}
      <span class="disabled">&larr; Newer</span>
    {{end}}
    <span>{{.RangeStart}}-{{.RangeEnd}} of {{.FilteredTotal}}</span>
    {{if .NextURL}}
      <a href="{{.NextURL}}">Older &rarr;</a>
    {{else}}
      <span class="disabled">Older &rarr;</span>
    {{end}}
  </nav>
{{end}}
{{- /* live.js polls /api/live-events and prepends new cards into
       #live-tape. data-since is the baseline timestamp the script
       starts from; the script updates it after each successful poll. */}}
<script src="/static/live.js" data-since="{{.PollSince}}" defer></script>
{{end}}
